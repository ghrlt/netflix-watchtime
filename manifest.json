{
    "name": "Netflix Watchtime",
    "description": "View and analyse your Netflix watch history — titles, trends and estimated watch time.",
    "version": "2.0.0",
    "manifest_version": 3,
    "author": "Gaëtan Hrlt",

    "icons": {
        "16": "medias/icon16.png",
        "48": "medias/icon48.png",
        "128": "medias/icon128.png"
    },

    "default_locale": "en",

    "action": {
        "default_title": "Netflix Watchtime"
    },

    "background": {
        "service_worker": "background.js"
    },

    "host_permissions": [
        "https://*.netflix.com/*"
    ],
    "permissions": [
        "scripting",
        "tabs"
    ]
}
